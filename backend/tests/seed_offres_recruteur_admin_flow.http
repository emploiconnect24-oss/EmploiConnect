### --- 4) Creer offre #3 ------------------------------------
POST {{base}}/recruteur/offres
Authorization: Bearer {{tokenRecruteur}}
Content-Type: application/json

{
  "titre": "Assistant Comptable Seed #3",
  "description": "Poste seed automatique pour verifier notifications admin.",
  "exigences": "Licence, maitrise des outils bureautiques.",
  "competences_requises": ["Comptabilite", "Sage", "Excel"],
  "localisation": "Conakry",
  "type_contrat": "cdd",
  "niveau_experience_requis": "1-2 ans",
  "domaine": "Finance",
