### ==========================================================
### 0-bis) LOGIN (si tu as "Token invalide")
### 1) Execute ces 2 requetes
### 2) Copie chaque "token" retourne
### 3) Remplace @tokenRecruteur et @tokenAdmin en haut
### ==========================================================

### --- 0-ter) REGISTER (optionnel, si login echoue) ----------
### Si compte existe deja, tu auras 409 (normal) -> passe au login

POST {{base}}/auth/register
Content-Type: application/json

{
  "email": "{{emailRecruteur}}",
  "mot_de_passe": "{{passwordRecruteur}}",
  "nom": "{{nomRecruteur}}",
  "role": "entreprise"
}

###

POST {{base}}/auth/register
Content-Type: application/json

{
  "email": "{{emailAdmin}}",
  "mot_de_passe": "{{passwordAdmin}}",
  "nom": "{{nomAdmin}}",
  "role": "admin"
}

###

POST {{base}}/auth/login
Content-Type: application/json

{
  "email": "{{emailRecruteur}}",
  "mot_de_passe": "{{passwordRecruteur}}"
}

###

POST {{base}}/auth/login
Content-Type: application/json

{
  "email": "{{emailAdmin}}",
  "mot_de_passe": "{{passwordAdmin}}"
}

### --- 1) Verifier dashboard admin AVANT seed ---------------
GET {{base}}/admin/dashboard
Authorization: Bearer {{tokenAdmin}}

###

### --- 2) Creer offre #1 (statut attendu: en_attente) -------
POST {{base}}/recruteur/offres
Authorization: Bearer {{tokenRecruteur}}
Content-Type: application/json

{
  "titre": "Assistant Comptable Seed #1",
  "description": "Poste seed automatique pour tester le flux admin/recruteur.",
  "exigences": "Licence, 1-2 ans, maitrise Excel et comptabilite generale.",
  "competences_requises": ["Comptabilite", "Excel", "Reporting"],
  "localisation": "Conakry",
  "type_contrat": "cdd",
  "niveau_experience_requis": "1-2 ans",
  "domaine": "Finance",
  "salaire_min": 3000000,
  "salaire_max": 5000000,
  "devise": "GNF",
  "nombre_postes": 1,
  "publier_maintenant": true
}

###

### --- 3) Creer offre #2 ------------------------------------
POST {{base}}/recruteur/offres
Authorization: Bearer {{tokenRecruteur}}
Content-Type: application/json

{
  "titre": "Assistant Comptable Seed #2",
  "description": "Poste seed automatique pour tester les compteurs admin.",
  "exigences": "Licence, 1-2 ans, rigueur et organisation.",
  "competences_requises": ["Comptabilite", "Excel"],
  "localisation": "Conakry",
